# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# State / runtime
.ship/

# Spike (throwaway — see docs/features/ship-v1/plan.md Phase 0)
spike/

# Personal background design notes — kept on disk, not in the repo
docs/cursor-dev-workflow-mcp-design (1).md
docs/ship-agent-communication-layer.pdf

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Env
.env
.env.local
.env.*.local

# Local credentials (never commit). Defensive — keys live outside the
# repo by default (`..\.keys`); these patterns catch any case where a
# key file is dropped into the repo root for live e2e convenience.
.keys
.keys.*
*.key
*.secret
credentials.json
# Vim undo files (e.g. `..keys.un~` for an edited `.keys` file would
# otherwise leak partial credential content if accidentally staged).
*.un~

# Misc
*.log
coverage/

# Stryker mutation reports (regenerated locally / in CI artifacts)
packages/*/reports/
packages/*/.stryker-tmp/

# Claude Code (CLI harness state — local only, except .claude/skills/
# which holds project-local skills that should be versioned with the repo).
.claude/*
!.claude/skills/

# Tower worktrees (per-task workspaces; never committed)
.worktrees/
.cloud-validation-spec.json
